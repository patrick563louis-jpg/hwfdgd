---
const { post } = Astro.props;

const categoryLabels: Record<string, string> = {
  'ai-services': 'خدمات الذكاء الاصطناعي',
  'money-ai': 'Money Ai',
  'ai-tools': 'أدوات الذكاء الاصطناعي',
  'general': 'عام',
};

const toolTypeLabels: Record<string, { label: string; icon: string }> = {
  'ai-assistant':      { label: 'مساعد ذكي',       icon: '🤖' },
  'image-generation':  { label: 'توليد صور',        icon: '🎨' },
  'video-generation':  { label: 'توليد فيديو',      icon: '🎬' },
  'audio-generation':  { label: 'توليد صوت',        icon: '🎵' },
  'automation':        { label: 'أتمتة',             icon: '⚙️' },
  'translation':       { label: 'ترجمة',             icon: '🌐' },
  'writing':           { label: 'كتابة',             icon: '✍️' },
  'coding':            { label: 'برمجة',             icon: '💻' },
  'other':             { label: 'أخرى',              icon: '✨' },
};

const appTypeLabels: Record<string, { label: string; icon: string }> = {
  'software':         { label: 'برامج', icon: '💻' },
  'ebooks':           { label: 'كتب إلكترونية', icon: '📚' },
  'design-templates': { label: 'قوالب تصميم', icon: '🎨' },
  'digital-bundles':  { label: 'حزم رقمية', icon: '📦' },
  'other':            { label: 'أخرى', icon: '✨' },
};

const subType = post.data.toolType
  ? toolTypeLabels[post.data.toolType]
  : post.data.appType
  ? appTypeLabels[post.data.appType]
  : null;

// Extract first image from markdown body
const imgMatch = post.body.match(/!\[.*?\]\((.*?)\)/);
const firstImage = imgMatch ? imgMatch[1] : null;

// Also check frontmatter image field
const thumbnail = post.data.image || firstImage || null;
---

<article class="post-card">
  {thumbnail && (
    <a href={`/posts/${post.slug}`} class="post-thumbnail">
      <img src={thumbnail} alt={post.data.title} loading="lazy" />
    </a>
  )}
  <div class="post-body">
    <div class="post-badges">
      <div class="post-category">{categoryLabels[post.data.category] ?? post.data.category}</div>
      {subType && (
        <div class="post-subtype">{subType.icon} {subType.label}</div>
      )}
    </div>
    <h2><a href={`/posts/${post.slug}`}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <div class="post-meta">
      <span class="post-date">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="16" y1="2" x2="16" y2="6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="8" y1="2" x2="8" y2="6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="3" y1="10" x2="21" y2="10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {post.data.pubDate.toLocaleDateString('en-GB')}
      </span>
      {post.data.author && (
        <span class="post-author">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="7" r="4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {post.data.author}
        </span>
      )}
    </div>
    <a href={`/posts/${post.slug}`} class="read-more">
      اقرأ المزيد
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</article>

<style>
  .post-card {
    background: white;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-primary-light);
  }

  .post-thumbnail {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .post-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .post-card:hover .post-thumbnail img {
    transform: scale(1.05);
  }

  .post-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }

  .post-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-category {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    color: white;
    font-size: 0.72rem;
    font-weight: 600;
    border-radius: 0.375rem;
    width: fit-content;
  }

  .post-subtype {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.65rem;
    background: var(--color-bg-secondary, #f3f4f6);
    color: var(--color-text-secondary, #6b7280);
    font-size: 0.72rem;
    font-weight: 600;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border, #e5e7eb);
    width: fit-content;
  }

  .post-card h2 {
    font-size: 1.15rem;
    margin: 0;
    line-height: 1.4;
  }

  .post-card h2 a {
    color: var(--color-text);
    transition: color 0.2s;
  }

  .post-card h2 a:hover {
    color: var(--color-primary);
  }

  .post-card p {
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    font-size: 0.9rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    padding: 0.65rem 0;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .post-meta span {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--color-text-light);
  }

  .post-meta svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: all 0.2s ease;
  }

  .read-more:hover {
    gap: 0.65rem;
    color: var(--color-primary-dark);
  }
</style>
