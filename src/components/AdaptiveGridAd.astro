---
// Adaptive Grid Ad Component
// This component is designed to be inserted into the grid and will appear between rows
interface Props {
	slot: string;
	className?: string;
}

const { slot, className = '' } = Astro.props;
---

<div class={`adaptive-grid-ad ${className}`} data-ad-slot={slot}>
	<div class="ad-container">
		<ins class="adsbygoogle"
			style="display:block"
			data-ad-client={import.meta.env.PUBLIC_ADSENSE_CLIENT_ID}
			data-ad-slot={slot}
			data-ad-format="auto"
			data-full-width-responsive="true">
		</ins>
	</div>
</div>

<script>
	// Push ads when component loads
	if (typeof window !== 'undefined') {
		try {
			((window as any).adsbygoogle = (window as any).adsbygoogle || []).push({});
		} catch (e) {
			console.error('AdSense error:', e);
		}
	}
</script>

<style>
	.adaptive-grid-ad {
		grid-column: 1 / -1;
		display: flex;
		justify-content: center;
		align-items: center;
		margin: 1.5rem 0;
		min-height: 100px;
	}

	.ad-container {
		width: 100%;
		max-width: 728px;
		display: flex;
		justify-content: center;
	}

	.adsbygoogle {
		display: block;
		width: 100%;
	}
</style>
