---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import AdSense from '../components/AdSense.astro';
import GridAdSystem from '../components/GridAdSystem.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
	title="مدونة خدمات الذكاء الاصطناعي | أحدث المقالات والدروس التقنية"
	description="تابع أحدث مقالاتنا حول أدوات وتقنيات الذكاء الاصطناعي. دروس تعليمية، مراجعات أدوات، واستراتيجيات مبتكرة لتطوير مهاراتك الرقمية والمالية."
>
	<Header />

	<main>
		<section class="posts-section">
			<div class="container">
				<div class="page-header">
					<div class="page-title">
						<h1>المقالات</h1>
						<p><span id="postCount">{sortedPosts.length}</span> مقال</p>
					</div>
					<div class="search-box">
						<input 
							type="text" 
							id="searchInput" 
							placeholder="ابحث في المقالات..." 
							aria-label="بحث في المقالات"
						/>
						<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<path d="m21 21-4.35-4.35"></path>
						</svg>
					</div>
				</div>

				<!-- Horizontal scrollable filter bar -->
				<div class="filters-wrapper">
					<div class="filters" id="filtersBar">
						<button class="filter-btn active" data-category="all" id="filter-all">الكل ({allPosts.length})</button>
						<button class="filter-btn" data-category="ai-services" id="filter-ai-services">
							خدمات الذكاء الاصطناعي ({allPosts.filter(p => p.data.category === 'ai-services').length})
						</button>
						<button class="filter-btn" data-category="money-ai" id="filter-money-ai">
							Money Ai ({allPosts.filter(p => p.data.category === 'money-ai').length})
						</button>
						<button class="filter-btn" data-category="ai-tools" id="filter-ai-tools">
							أدوات الذكاء الاصطناعي ({allPosts.filter(p => p.data.category === 'ai-tools').length})
						</button>
						<button class="filter-btn" data-category="general" id="filter-general">
							عام ({allPosts.filter(p => p.data.category === 'general').length})
						</button>
					</div>
				</div>

				<!-- Ad before posts -->
				<div class="ad-section">
					<AdSense slot="4444444444" format="horizontal" />
				</div>

				<div class="posts-grid" id="postsGrid">
					{sortedPosts.map((post) => (
						<div class="post-wrapper" data-category={post.data.category}>
							<PostCard post={post} />
						</div>
					))}
				</div>

				<GridAdSystem slot="5555555555" />

				<!-- Ad after posts -->
				<div class="ad-section">
					<AdSense slot="6666666666" format="horizontal" />
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script>
	const filterBtns = document.querySelectorAll('.filter-btn');
	const postWrappers = document.querySelectorAll('.post-wrapper');
	const filtersBar = document.getElementById('filtersBar') as HTMLElement;
	const searchInput = document.getElementById('searchInput') as HTMLInputElement;
	const postCount = document.getElementById('postCount');
	const postsGrid = document.getElementById('postsGrid') as HTMLElement;
	let currentCategory = 'all';

	function init() {
		const params = new URLSearchParams(window.location.search);
		const filter = params.get('filter') || 'all';
		const query = params.get('q') || '';

		if (searchInput) {
			searchInput.value = query;
		}

		currentCategory = filter;
		filterBtns.forEach(b => b.classList.remove('active'));
		const activeBtn = document.getElementById(`filter-${filter}`) as HTMLButtonElement;
		
		if (activeBtn) {
			activeBtn.classList.add('active');
			setTimeout(() => scrollActiveIntoView(activeBtn), 50);
		} else {
			const allBtn = document.getElementById('filter-all') as HTMLButtonElement;
			if (allBtn) {
				allBtn.classList.add('active');
				setTimeout(() => scrollActiveIntoView(allBtn), 50);
			}
		}

		applyFilters();
	}

	function updateURL() {
		const params = new URLSearchParams();
		const searchTerm = searchInput?.value.toLowerCase().trim();

		if (currentCategory !== 'all') {
			params.set('filter', currentCategory);
		}
		if (searchTerm) {
			params.set('q', searchTerm);
		}

		const queryString = params.toString();
		const newUrl = `${window.location.pathname}${queryString ? '?' + queryString : ''}`;
		window.history.pushState({ filter: currentCategory, q: searchTerm }, '', newUrl);
	}

	window.addEventListener('popstate', (event) => {
		init();
	});

	function scrollActiveIntoView(btn: HTMLButtonElement) {
		if (!btn || !filtersBar) return;
		const barRect = filtersBar.getBoundingClientRect();
		const btnRect = btn.getBoundingClientRect();
		
		// Calculate the scroll position to center the button
		const scrollTarget = btn.offsetLeft - (barRect.width / 2) + (btnRect.width / 2);
		
		filtersBar.scrollTo({
			left: scrollTarget,
			behavior: 'smooth'
		});
	}

	// Re-scroll on window resize to keep active button visible
	let resizeTimeout: any;
	window.addEventListener('resize', () => {
		clearTimeout(resizeTimeout);
		resizeTimeout = setTimeout(() => {
			const activeBtn = document.querySelector('.filter-btn.active') as HTMLButtonElement;
			if (activeBtn) scrollActiveIntoView(activeBtn);
		}, 100);
	});

	// Filter by category
	filterBtns.forEach(btn => {
		const filterBtn = btn as HTMLButtonElement;
		filterBtn.addEventListener('click', () => {
			currentCategory = filterBtn.getAttribute('data-category') || 'all';
			filterBtns.forEach(b => b.classList.remove('active'));
			filterBtn.classList.add('active');
			scrollActiveIntoView(filterBtn);
			applyFilters();
			updateURL();
		});
	});

	// Search functionality
	searchInput?.addEventListener('input', () => {
		applyFilters();
		updateURL();
	});

	// Initialize on page load
	init();

	function applyFilters() {
		const searchTerm = searchInput?.value.toLowerCase().trim() || '';
		let visibleCount = 0;

		postWrappers.forEach((wrapper) => {
			const el = wrapper as HTMLElement;
			const category = el.getAttribute('data-category');
			const title = el.querySelector('h2')?.textContent?.toLowerCase() || '';
			const description = el.querySelector('p')?.textContent?.toLowerCase() || '';
			
			const matchesCategory = currentCategory === 'all' || category === currentCategory;
			const matchesSearch = !searchTerm || title.includes(searchTerm) || description.includes(searchTerm);

			if (matchesCategory && matchesSearch) {
				el.style.display = 'flex';
				visibleCount++;
			} else {
				el.style.display = 'none';
			}
		});

		// Update post count
		if (postCount) {
			postCount.textContent = visibleCount.toString();
		}
	}
</script>

<style>
	.posts-section {
		padding: 3rem 0 5rem;
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}

	.page-title h1 {
		font-size: 2rem;
		margin-bottom: 0.25rem;
	}

	.page-title p {
		color: var(--color-text-secondary);
		font-size: 0.95rem;
	}

	.search-box {
		position: relative;
		flex: 0 1 300px;
		min-width: 200px;
	}

	.search-box input {
		width: 100%;
		padding: 0.65rem 2.75rem 0.65rem 1rem;
		border: 2px solid var(--color-border);
		border-radius: 0.5rem;
		font-size: 0.9rem;
		font-family: inherit;
		transition: all 0.2s ease;
		background: white;
	}

	.search-box input:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
	}

	.search-box input::placeholder {
		color: var(--color-text-secondary);
	}

	.search-icon {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--color-text-secondary);
		pointer-events: none;
	}

	/* Filters wrapper with fade edges */
	.filters-wrapper {
		position: relative;
		margin-bottom: 2.5rem;
	}

	.filters-wrapper::before,
	.filters-wrapper::after {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		width: 48px;
		z-index: 2;
		pointer-events: none;
	}

	.filters-wrapper::before {
		right: 0;
		background: linear-gradient(to left, #ffffff 30%, transparent 100%);
	}

	.filters-wrapper::after {
		left: 0;
		background: linear-gradient(to right, #ffffff 30%, transparent 100%);
	}

	.filters {
		display: flex;
		gap: 0.75rem;
		overflow-x: auto;
		padding: 0.5rem 0;
		scrollbar-width: none; /* Firefox */
		-ms-overflow-style: none; /* IE and Edge */
		position: relative;
	}

	.filters::-webkit-scrollbar {
		display: none; /* Chrome, Safari and Opera */
	}

	.filter-btn {
		padding: 0.6rem 1.25rem;
		border-radius: 2rem;
		border: 1px solid var(--color-border);
		background: white;
		color: var(--color-text-secondary);
		font-size: 0.9rem;
		font-weight: 500;
		cursor: pointer;
		white-space: nowrap;
		transition: all 0.2s ease;
		flex-shrink: 0;
	}

	.filter-btn:hover {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	.filter-btn.active {
		background: var(--color-primary);
		border-color: var(--color-primary);
		color: white;
		box-shadow: 0 4px 12px rgba(13, 148, 136, 0.2);
	}

	.ad-section {
		margin: 2rem 0;
		display: flex;
		justify-content: center;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 2rem;
		margin-bottom: 3rem;
	}

	@media (max-width: 768px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}

		.page-header {
			flex-direction: column;
			align-items: stretch;
		}

		.search-box {
			flex: 1;
		}
	}
</style>
