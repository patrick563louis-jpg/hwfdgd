---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import GridAdSystem from '../components/GridAdSystem.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const recentPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<Layout 
	title="خدمات الذكاء الاصطناعي | دليلك المتكامل لاستخدام وتطبيقات AI" 
	description="المنصة الرائدة في تمكين الأفراد والشركات من خلال تقنيات الذكاء الاصطناعي. استكشف أفضل الأدوات، الشروحات التقنية، واستراتيجيات الاستثمار الذكي لتحويل أعمالك نحو الابتكار الرقمي."
>
	<Header />

	<main>
		<!-- Top Ad -->
		<div class="container">
			<AdSense slot="1010101010" format="horizontal" className="home-top-ad" />
		</div>

		<section class="recent-posts">
			<div class="container">
				<div class="section-header">
					<h2>أحدث المقالات</h2>
					<p>اطلع على آخر الأخبار والمقالات حول الذكاء الاصطناعي</p>
				</div>
				<div class="posts-grid">
					{recentPosts.map((post) => (
						<article class="post-wrapper">
							<div class="post-card">
								<div class="post-category">{
									post.data.category === 'ai-services' ? 'خدمات الذكاء الاصطناعي' :
									post.data.category === 'money-ai' ? 'الذكاء المالي' :
									'عام'
								}</div>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<div class="post-meta">
									<span class="post-date">{post.data.pubDate.toLocaleDateString('ar-SA')}</span>
									<a href={`/posts/${post.slug}`} class="post-link">
										اقرأ المزيد
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
											<path d="M5 12h14M12 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
										</svg>
									</a>
								</div>
							</div>
						</article>
					))}
				</div>
				<GridAdSystem slot="3030303030" />
				<div class="section-footer">
					<a href="/posts" class="btn btn-outline">عرض جميع المقالات</a>
				</div>

				<!-- Middle Ad -->
				<AdSense slot="2020202020" format="horizontal" className="home-middle-ad" />
			</div>
		</section>

		<section class="cta">
			<div class="container">
				<div class="cta-content">
					<h2>جاهز للبدء؟</h2>
					<p>انضم إلى مئات الشركات التي تثق بنا لتحويل أعمالها باستخدام الذكاء الاصطناعي</p>
					<a href="#contact" class="btn btn-accent">تواصل معنا الآن</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.home-top-ad {
		margin: 2rem auto;
		max-width: 1200px;
	}

	.home-middle-ad {
		margin-top: 3rem;
	}

	.hero {
		padding: 6rem 0;
		background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
		overflow: hidden;
	}

	.hero-content {
		max-width: 600px;
	}

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1.1;
		margin-bottom: 1.5rem;
	}

	.gradient-text {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-description {
		font-size: 1.25rem;
		color: var(--color-text-secondary);
		margin-bottom: 2rem;
		line-height: 1.8;
	}

	.hero-buttons {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.hero-illustration {
		display: none;
	}

	@media (min-width: 768px) {
		.hero .container {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
			align-items: center;
		}

		.hero-illustration {
			display: block;
			position: relative;
			height: 400px;
		}

		.floating-card {
			position: absolute;
			background: white;
			padding: 1.5rem;
			border-radius: 1rem;
			box-shadow: var(--shadow-xl);
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.5rem;
			animation: float 3s ease-in-out infinite;
		}

		.floating-card svg {
			color: var(--color-primary);
		}

		.floating-card span {
			font-weight: 600;
			font-size: 0.875rem;
			color: var(--color-text);
		}

		.card-1 {
			top: 10%;
			right: 20%;
			animation-delay: 0s;
		}

		.card-2 {
			top: 50%;
			right: 10%;
			animation-delay: 1s;
		}

		.card-3 {
			bottom: 10%;
			right: 30%;
			animation-delay: 2s;
		}

		@keyframes float {
			0%, 100% {
				transform: translateY(0);
			}
			50% {
				transform: translateY(-20px);
			}
		}
	}

	.features {
		padding: 6rem 0;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-header h2 {
		margin-bottom: 1rem;
	}

	.section-header p {
		font-size: 1.125rem;
		max-width: 600px;
		margin: 0 auto;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
	}

	.feature-card {
		padding: 2rem;
		background: white;
		border: 1px solid var(--color-border);
		border-radius: 1rem;
		transition: all 0.3s ease;
	}

	.feature-card:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-lg);
		border-color: var(--color-primary-light);
	}

	.feature-icon {
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--color-bg-tertiary) 0%, var(--color-bg-secondary) 100%);
		border-radius: 1rem;
		margin-bottom: 1.5rem;
		color: var(--color-primary);
	}

	.feature-card h3 {
		margin-bottom: 0.75rem;
		font-size: 1.25rem;
	}

	.feature-card p {
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.recent-posts {
		padding: 6rem 0;
		background: var(--color-bg-secondary);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		margin-bottom: 3rem;
	}

	.post-wrapper {
		display: flex;
	}

	.post-card {
		background: white;
		padding: 2rem;
		border-radius: 1rem;
		box-shadow: var(--shadow-md);
		transition: all 0.3s ease;
	}

	.post-card:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-xl);
	}

	.post-category {
		display: inline-block;
		padding: 0.375rem 0.75rem;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
		color: white;
		font-size: 0.75rem;
		font-weight: 600;
		border-radius: 0.375rem;
		margin-bottom: 1rem;
	}

	.post-card h3 {
		font-size: 1.25rem;
		margin-bottom: 0.75rem;
		color: var(--color-text);
	}

	.post-card p {
		color: var(--color-text-secondary);
		margin-bottom: 1.5rem;
		line-height: 1.7;
	}

	.post-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
	}

	.post-date {
		font-size: 0.875rem;
		color: var(--color-text-light);
	}

	.post-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 600;
		color: var(--color-primary);
	}

	.post-link:hover {
		gap: 0.75rem;
	}

	.post-link svg {
		transition: transform 0.3s ease;
	}

	.section-footer {
		text-align: center;
	}

	.cta {
		padding: 6rem 0;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
		color: white;
	}

	.cta-content {
		text-align: center;
		max-width: 700px;
		margin: 0 auto;
	}

	.cta h2 {
		color: white;
		margin-bottom: 1rem;
	}

	.cta p {
		font-size: 1.125rem;
		color: rgba(255, 255, 255, 0.9);
		margin-bottom: 2rem;
	}

	@media (max-width: 768px) {
		.hero {
			padding: 4rem 0;
		}

		.hero-buttons {
			flex-direction: column;
		}

		.hero-buttons .btn {
			width: 100%;
		}

		.features,
		.recent-posts,
		.cta {
			padding: 4rem 0;
		}

		.section-header {
			margin-bottom: 2.5rem;
		}

		.features-grid,
		.posts-grid {
			gap: 1.5rem;
		}
	}
</style>
