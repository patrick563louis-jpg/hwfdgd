---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import InArticleAd from '../../components/InArticleAd.astro';
import AdSense from '../../components/AdSense.astro';
import GridAdSystem from '../../components/GridAdSystem.astro';
import AdBlock from '../../components/AdBlock.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map(post => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Components for Markdoc
const components = {
	AdBlock: AdBlock,
};

const categoryLabels: Record<string, string> = {
	'ai-services': 'خدمات الذكاء الاصطناعي',
	'money-ai': 'Money AI',
	'ai-tools': 'أدوات الذكاء الاصطناعي',
	'apps': 'تطبيقات الذكاء الاصطناعي',
	'general': 'عام',
};

const categoryName = categoryLabels[post.data.category] ?? post.data.category;

const categoryUrlMap: Record<string, string> = {
	'ai-services': 'services',
	'money-ai': 'money-ai',
	'ai-tools': 'ai-tools',
	'apps': 'apps',
	'general': 'posts',
};

const categoryUrl = categoryUrlMap[post.data.category] || 'posts';

// Get recommended posts: same category first, then others, exclude current post, max 3
const allPosts = await getCollection('posts');
const sameCategoryPosts = allPosts
	.filter(p => p.slug !== post.slug && p.data.category === post.data.category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const otherPosts = allPosts
	.filter(p => p.slug !== post.slug && p.data.category !== post.data.category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recommendedPosts = [...sameCategoryPosts, ...otherPosts].slice(0, 3);
---

<Layout
	title={`${post.data.title} | خدمات الذكاء الاصطناعي`}
	description={post.data.description}
	image={post.data.image}
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		"headline": post.data.title,
		"description": post.data.description,
		"image": [new URL(post.data.image || '/media/images/general-ai.jpg', 'https://khadamatelai.xyz').toString()],
		"datePublished": post.data.pubDate.toISOString(),
		"author": [{
			"@type": "Person",
			"name": post.data.author || "فريق خدمات الذكاء الاصطناعي",
			"url": "https://khadamatelai.xyz"
		}],
		"publisher": {
			"@type": "Organization",
			"name": "خدمات الذكاء الاصطناعي",
			"logo": {
				"@type": "ImageObject",
				"url": "https://khadamatelai.xyz/favicon.svg"
			}
		},
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": new URL(Astro.url.pathname, 'https://khadamatelai.xyz').toString()
		}
	})} />

	<script type="application/ld+json" slot="head" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"name": "الرئيسية",
				"item": "https://khadamatelai.xyz"
			},
			{
				"@type": "ListItem",
				"position": 2,
				"name": categoryName,
				"item": `https://khadamatelai.xyz/${categoryUrl}`
			},
			{
				"@type": "ListItem",
				"position": 3,
				"name": post.data.title,
				"item": new URL(Astro.url.pathname, 'https://khadamatelai.xyz').toString()
			}
		]
	})} />
	<Header />

	<main>
		<article class="post-article">
			<div class="container">
				<div class="post-header">
					<div class="breadcrumb">
						<a href="/">الرئيسية</a>
						<span>/</span>
						<a href={`/${categoryUrl}`}>{categoryName}</a>
						<span>/</span>
						<span class="current">{post.data.title}</span>
					</div>

					<div class="post-category">{categoryName}</div>

					<h1>{post.data.title}</h1>

					<p class="post-description">{post.data.description}</p>

					<div class="post-meta">
						<span class="meta-item">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
								<rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<line x1="16" y1="2" x2="16" y2="6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<line x1="8" y1="2" x2="8" y2="6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<line x1="3" y1="10" x2="21" y2="10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							{post.data.pubDate.toLocaleDateString('ar-SA-u-nu-latn', {
								year: 'numeric',
								month: 'long',
								day: 'numeric'
							})}
						</span>
						{post.data.author && (
							<span class="meta-item">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
									<path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
									<circle cx="12" cy="7" r="4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
								{post.data.author}
							</span>
						)}
					</div>
				</div>

				{post.data.image && (
					<div class="post-hero-image">
						<img src={post.data.image} alt={post.data.title} loading="eager" />
					</div>
				)}

				<!-- Ad before content -->
				<div class="ad-container">
					<AdSense slot="1111111111" format="horizontal" />
				</div>

				<div class="post-content">
					<Content components={components} />
					
					<!-- In-article ad (appears in the middle of content) -->
					<InArticleAd slot="2222222222" />
				</div>

				<!-- Ad after content -->
				<div class="ad-container">
					<AdSense slot="3333333333" format="horizontal" />
				</div>

				<div class="post-footer">
					<a href="/posts" class="back-link">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
							<path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						العودة إلى المقالات
					</a>
				</div>
			</div>
		</article>

		{recommendedPosts.length > 0 && (
			<section class="recommended-section">
				<div class="container">
					<h2 class="recommended-title">مقالات قد تعجبك</h2>
					<div class="recommended-grid posts-grid">
						{recommendedPosts.map((recPost) => (
							<div class="post-wrapper">
								<PostCard post={recPost} />
							</div>
						))}
					</div>
					<GridAdSystem slot="4040404040" />
				</div>
			</section>
		)}
	</main>

	<Footer />
</Layout>

<style>
	.post-article {
		padding: 4rem 0;
		background: var(--color-bg);
	}

	.post-header {
		max-width: 800px;
		margin: 0 auto 3rem;
		text-align: center;
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		margin-bottom: 2rem;
		font-size: 0.875rem;
		flex-wrap: wrap;
	}

	.breadcrumb a {
		color: var(--color-text-secondary);
		transition: color 0.3s ease;
	}

	.breadcrumb a:hover {
		color: var(--color-primary);
	}

	.breadcrumb span {
		color: var(--color-text-light);
	}

	.breadcrumb .current {
		color: var(--color-primary);
		font-weight: 600;
	}

	.post-category {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
		color: white;
		font-size: 0.875rem;
		font-weight: 600;
		border-radius: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.post-header h1 {
		margin-bottom: 1rem;
		line-height: 1.3;
	}

	.post-description {
		font-size: 1.25rem;
		color: var(--color-text-secondary);
		margin-bottom: 2rem;
		line-height: 1.8;
	}

	.post-meta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		padding: 1.5rem;
		background: var(--color-bg-secondary);
		border-radius: 0.75rem;
		flex-wrap: wrap;
	}

	.meta-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--color-text-secondary);
		font-size: 0.9375rem;
		font-weight: 500;
	}

	.meta-item svg {
		color: var(--color-primary);
	}

	.post-hero-image {
		max-width: 800px;
		margin: 0 auto 2.5rem;
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-md);
	}

	.post-hero-image img {
		width: 100%;
		height: auto;
		display: block;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.post-content {
		max-width: 800px;
		margin: 0 auto;
		background: white;
		padding: 3rem;
		border-radius: 1rem;
		box-shadow: var(--shadow-md);
		line-height: 1.8;
	}

	.post-content :global(h1),
	.post-content :global(h2),
	.post-content :global(h3),
	.post-content :global(h4),
	.post-content :global(h5),
	.post-content :global(h6) {
		margin-top: 2rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.post-content :global(h1) {
		font-size: 2.5rem;
		border-bottom: 3px solid var(--color-primary);
		padding-bottom: 0.5rem;
	}

	.post-content :global(h2) {
		font-size: 2rem;
		color: var(--color-primary);
	}

	.post-content :global(h3) {
		font-size: 1.5rem;
	}

	.post-content :global(p) {
		margin-bottom: 1.5rem;
		color: var(--color-text-secondary);
		line-height: 1.9;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin: 1.5rem 0;
		padding-right: 2rem;
	}

	.post-content :global(li) {
		margin-bottom: 0.75rem;
		color: var(--color-text-secondary);
		line-height: 1.8;
	}

	.post-content :global(li strong) {
		color: var(--color-primary);
	}

	.post-content :global(strong) {
		color: var(--color-text);
		font-weight: 700;
	}

	.post-content :global(a) {
		color: var(--color-primary);
		text-decoration: underline;
		font-weight: 600;
	}

	.post-content :global(a:hover) {
		color: var(--color-primary-dark);
	}

	.post-content :global(blockquote) {
		border-right: 4px solid var(--color-primary);
		padding: 1rem 1.5rem;
		margin: 2rem 0;
		background: var(--color-bg-secondary);
		border-radius: 0.5rem;
		font-style: italic;
	}

	.post-content :global(code) {
		background: var(--color-bg-tertiary);
		padding: 0.25rem 0.5rem;
		border-radius: 0.25rem;
		font-family: 'Courier New', monospace;
		font-size: 0.875rem;
		color: var(--color-primary-dark);
	}

	.post-content :global(pre) {
		background: #1e293b;
		padding: 1.5rem;
		border-radius: 0.5rem;
		overflow-x: auto;
		margin: 2rem 0;
	}

	.post-content :global(pre code) {
		background: none;
		padding: 0;
		color: #e2e8f0;
	}

	.post-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 2rem 0;
		font-size: 0.95rem;
	}

	.post-content :global(th) {
		background: var(--color-primary);
		color: white;
		padding: 0.75rem 1rem;
		text-align: right;
		font-weight: 600;
	}

	.post-content :global(td) {
		padding: 0.75rem 1rem;
		border-bottom: 1px solid var(--color-border);
		color: var(--color-text-secondary);
	}

	.post-content :global(tr:nth-child(even) td) {
		background: var(--color-bg-secondary);
	}

	.ad-container {
		max-width: 800px;
		margin: 2rem auto;
	}

	.post-footer {
		max-width: 800px;
		margin: 3rem auto 0;
		padding-top: 2rem;
		border-top: 1px solid var(--color-border);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		background: var(--color-bg-secondary);
		border-radius: 0.5rem;
		font-weight: 600;
		color: var(--color-primary);
		transition: all 0.3s ease;
	}

	.back-link:hover {
		background: var(--color-primary);
		color: white;
		gap: 0.75rem;
	}

	/* Recommended Posts */
	.recommended-section {
		padding: 4rem 0 5rem;
		background: var(--color-bg-secondary);
		border-top: 1px solid var(--color-border);
	}

	.recommended-title {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		color: var(--color-text);
		position: relative;
		padding-bottom: 0.75rem;
	}

	.recommended-title::after {
		content: '';
		position: absolute;
		bottom: 0;
		right: 0;
		width: 60px;
		height: 3px;
		background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
		border-radius: 2px;
	}

	.recommended-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.post-wrapper {
		display: flex;
	}

	@media (max-width: 768px) {
		.post-article {
			padding: 3rem 0;
		}

		.post-header {
			margin-bottom: 2rem;
		}

		.post-content {
			padding: 2rem 1.5rem;
		}

		.post-content :global(h1) {
			font-size: 2rem;
		}

		.post-content :global(h2) {
			font-size: 1.5rem;
		}

		.post-content :global(h3) {
			font-size: 1.25rem;
		}

		.post-meta {
			gap: 1rem;
			padding: 1rem;
		}

		.meta-item {
			font-size: 0.875rem;
		}

		.recommended-section {
			padding: 3rem 0 4rem;
		}

		.recommended-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
