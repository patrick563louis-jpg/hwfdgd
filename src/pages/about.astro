---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="من نحن | خدمات الذكاء الاصطناعي" description="تعرف على فريق خدمات الذكاء الاصطناعي ورسالتنا في تمكين الأفراد والشركات من الاستفادة من تقنيات الذكاء الاصطناعي">
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="page-hero">
			<div class="container">
				<div class="hero-badge">من نحن</div>
				<h1>نحن نؤمن بقوة الذكاء الاصطناعي</h1>
				<p class="hero-subtitle">
					منصة متخصصة في تقديم خدمات وأدوات الذكاء الاصطناعي باللغة العربية، نسعى لتمكين كل فرد وشركة من الاستفادة القصوى من ثورة الذكاء الاصطناعي.
				</p>
			</div>
		</section>

		<!-- Mission Section -->
		<section class="section">
			<div class="container">
				<div class="content-grid">
					<div class="content-text">
						<h2>رسالتنا</h2>
						<p>
							نؤمن بأن الذكاء الاصطناعي ليس حكرًا على المتخصصين التقنيين، بل هو أداة يجب أن تكون في متناول الجميع. لذلك نعمل على تبسيط هذه التقنيات وتقديمها بأسلوب سهل ومفهوم باللغة العربية.
						</p>
						<p>
							نقدم محتوى تعليميًا متميزًا، ومراجعات شاملة لأدوات الذكاء الاصطناعي، وخدمات احترافية تساعد الأفراد والشركات على تحقيق أهدافهم باستخدام أحدث التقنيات.
						</p>
					</div>
					<div class="content-card">
						<div class="stat-grid">
							<div class="stat-item">
								<span class="stat-number">+500</span>
								<span class="stat-label">مقال ودليل</span>
							</div>
							<div class="stat-item">
								<span class="stat-number">+50</span>
								<span class="stat-label">أداة ذكاء اصطناعي</span>
							</div>
							<div class="stat-item">
								<span class="stat-number">+10K</span>
								<span class="stat-label">مستخدم نشط</span>
							</div>
							<div class="stat-item">
								<span class="stat-number">24/7</span>
								<span class="stat-label">دعم مستمر</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Values Section -->
		<section class="section section-alt">
			<div class="container">
				<div class="section-header">
					<h2>قيمنا</h2>
					<p>المبادئ التي تحكم عملنا وتوجه قراراتنا</p>
				</div>
				<div class="values-grid">
					<div class="value-card">
						<div class="value-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
						</div>
						<h3>الموثوقية</h3>
						<p>نلتزم بتقديم معلومات دقيقة وموثوقة مبنية على أبحاث ومصادر معتمدة.</p>
					</div>
					<div class="value-card">
						<div class="value-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M13 10V3L4 14h7v7l9-11h-7z"/>
							</svg>
						</div>
						<h3>الابتكار</h3>
						<p>نواكب أحدث التطورات في عالم الذكاء الاصطناعي ونقدمها لجمهورنا أولًا بأول.</p>
					</div>
					<div class="value-card">
						<div class="value-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
							</svg>
						</div>
						<h3>المجتمع</h3>
						<p>نبني مجتمعًا عربيًا متكاملًا من المهتمين بالذكاء الاصطناعي لتبادل المعرفة والخبرات.</p>
					</div>
					<div class="value-card">
						<div class="value-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
							</svg>
						</div>
						<h3>التعليم</h3>
						<p>نؤمن بأن التعليم هو المفتاح لاستثمار الذكاء الاصطناعي بشكل صحيح ومسؤول.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What We Offer Section -->
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2>ماذا نقدم</h2>
					<p>خدمات ومحتوى متنوع يلبي احتياجاتك في عالم الذكاء الاصطناعي</p>
				</div>
				<div class="offers-grid">
					<div class="offer-item">
						<div class="offer-num">01</div>
						<div class="offer-content">
							<h3>مقالات ودروس تعليمية</h3>
							<p>محتوى تعليمي شامل يغطي أحدث أدوات وتقنيات الذكاء الاصطناعي بأسلوب مبسط.</p>
						</div>
					</div>
					<div class="offer-item">
						<div class="offer-num">02</div>
						<div class="offer-content">
							<h3>مراجعات أدوات الذكاء الاصطناعي</h3>
							<p>تقييمات موضوعية ومفصلة لأبرز أدوات الذكاء الاصطناعي المتاحة في السوق.</p>
						</div>
					</div>
					<div class="offer-item">
						<div class="offer-num">03</div>
						<div class="offer-content">
							<h3>خدمات احترافية</h3>
							<p>حلول مخصصة للشركات والأفراد لتطبيق الذكاء الاصطناعي في أعمالهم.</p>
						</div>
					</div>
					<div class="offer-item">
						<div class="offer-num">04</div>
						<div class="offer-content">
							<h3>تطبيقات ذكية</h3>
							<p>تطبيقات مبتكرة تستخدم الذكاء الاصطناعي لحل مشكلات يومية وتحسين الإنتاجية.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact CTA -->
		<section class="section section-cta">
			<div class="container">
				<div class="cta-box">
					<h2>تواصل معنا</h2>
					<p>هل لديك سؤال أو اقتراح؟ نحن هنا للمساعدة</p>
					<a href="mailto:info@khadamatelai.xyz" class="btn btn-primary">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
						</svg>
						info@khadamatelai.xyz
					</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	main {
		min-height: 100vh;
	}

	/* Hero */
	.page-hero {
		background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #0d9488 100%);
		color: white;
		padding: 6rem 0 4rem;
		text-align: center;
	}

	.hero-badge {
		display: inline-block;
		background: rgba(255,255,255,0.15);
		border: 1px solid rgba(255,255,255,0.3);
		color: white;
		padding: 0.4rem 1.2rem;
		border-radius: 2rem;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		backdrop-filter: blur(10px);
	}

	.page-hero h1 {
		color: white;
		font-size: clamp(2rem, 5vw, 3rem);
		margin-bottom: 1.5rem;
	}

	.hero-subtitle {
		color: rgba(255,255,255,0.85);
		font-size: 1.15rem;
		max-width: 650px;
		margin: 0 auto;
		line-height: 1.8;
	}

	/* Sections */
	.section {
		padding: 5rem 0;
	}

	.section-alt {
		background: #f8fafc;
	}

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.section-header h2 {
		color: #0f172a;
		margin-bottom: 0.75rem;
	}

	.section-header p {
		color: #64748b;
		font-size: 1.1rem;
	}

	/* Content Grid */
	.content-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.content-text h2 {
		color: #0f172a;
		margin-bottom: 1.5rem;
	}

	.content-text p {
		color: #475569;
		line-height: 1.8;
		margin-bottom: 1rem;
	}

	.content-card {
		background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
		border-radius: 1.5rem;
		padding: 2.5rem;
	}

	.stat-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
	}

	.stat-item {
		text-align: center;
	}

	.stat-number {
		display: block;
		font-size: 2rem;
		font-weight: 900;
		color: #14b8a6;
		margin-bottom: 0.4rem;
	}

	.stat-label {
		color: rgba(255,255,255,0.75);
		font-size: 0.9rem;
	}

	/* Values */
	.values-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 2rem;
	}

	.value-card {
		background: white;
		border-radius: 1rem;
		padding: 2rem;
		box-shadow: 0 4px 20px rgba(0,0,0,0.06);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		text-align: center;
	}

	.value-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 12px 30px rgba(0,0,0,0.1);
	}

	.value-icon {
		width: 64px;
		height: 64px;
		background: linear-gradient(135deg, #0d9488, #1e3a8a);
		border-radius: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 1.25rem;
		color: white;
	}

	.value-card h3 {
		color: #0f172a;
		font-size: 1.15rem;
		margin-bottom: 0.75rem;
	}

	.value-card p {
		color: #64748b;
		font-size: 0.95rem;
		line-height: 1.7;
		margin: 0;
	}

	/* Offers */
	.offers-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}

	.offer-item {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
		padding: 1.75rem;
		background: white;
		border-radius: 1rem;
		border: 1px solid #e2e8f0;
		transition: border-color 0.3s ease, box-shadow 0.3s ease;
	}

	.offer-item:hover {
		border-color: #0d9488;
		box-shadow: 0 8px 24px rgba(13,148,136,0.1);
	}

	.offer-num {
		font-size: 2rem;
		font-weight: 900;
		color: #0d9488;
		opacity: 0.4;
		line-height: 1;
		flex-shrink: 0;
	}

	.offer-content h3 {
		color: #0f172a;
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
	}

	.offer-content p {
		color: #64748b;
		font-size: 0.95rem;
		line-height: 1.7;
		margin: 0;
	}

	/* CTA */
	.section-cta {
		background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
	}

	.cta-box {
		text-align: center;
		color: white;
	}

	.cta-box h2 {
		color: white;
		margin-bottom: 1rem;
	}

	.cta-box p {
		color: rgba(255,255,255,0.8);
		font-size: 1.1rem;
		margin-bottom: 2rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.85rem 2rem;
		border-radius: 0.6rem;
		font-weight: 600;
		font-size: 1rem;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.btn-primary {
		background: #0d9488;
		color: white;
	}

	.btn-primary:hover {
		background: #0f766e;
		transform: translateY(-2px);
		color: white;
	}

	@media (max-width: 768px) {
		.content-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.page-hero {
			padding: 4rem 0 3rem;
		}
	}
</style>
