---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 | الصفحة غير موجودة" description="عذراً، الصفحة التي تبحث عنها غير موجودة أو تم نقلها.">
	<Header />

	<main class="error-page">
		<div class="container">
			<div class="error-content">
				<div class="error-code">404</div>
				<h1>الصفحة غير موجودة</h1>
				<p>عذراً، الصفحة التي تبحث عنها غير موجودة أو تم نقلها. يمكنك العودة إلى الصفحة الرئيسية أو تصفح مقالاتنا.</p>
				<div class="error-actions">
					<a href="/" class="btn btn-primary">العودة للرئيسية</a>
					<a href="/posts" class="btn btn-outline">تصفح المقالات</a>
				</div>
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.error-page {
		padding: 8rem 0;
		text-align: center;
		background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
		min-height: 60vh;
		display: flex;
		align-items: center;
	}

	.error-content {
		max-width: 600px;
		margin: 0 auto;
	}

	.error-code {
		font-size: 8rem;
		font-weight: 900;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		line-height: 1;
		margin-bottom: 1rem;
	}

	h1 {
		margin-bottom: 1.5rem;
	}

	p {
		font-size: 1.25rem;
		color: var(--color-text-secondary);
		margin-bottom: 2.5rem;
	}

	.error-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn-outline {
		background: transparent;
		border: 2px solid var(--color-primary);
		color: var(--color-primary);
	}

	.btn-outline:hover {
		background: var(--color-primary);
		color: white;
	}

	@media (max-width: 768px) {
		.error-page {
			padding: 4rem 0;
		}
		
		.error-code {
			font-size: 6rem;
		}
	}
</style>
