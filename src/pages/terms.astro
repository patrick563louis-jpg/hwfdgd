---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = "21 مارس 2026";
---

<Layout title="الشروط والأحكام | خدمات الذكاء الاصطناعي" description="الشروط والأحكام لموقع خدمات الذكاء الاصطناعي - اقرأ شروط استخدام الموقع وخدماتنا بعناية">
	<Header />

	<main>
		<!-- Hero -->
		<section class="page-hero">
			<div class="container">
				<div class="hero-badge">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
					</svg>
					الشروط والأحكام
				</div>
				<h1>الشروط والأحكام</h1>
				<p class="hero-subtitle">يُرجى قراءة هذه الشروط بعناية قبل استخدام موقعنا وخدماتنا. استخدامك للموقع يعني موافقتك على هذه الشروط.</p>
				<div class="last-updated">آخر تحديث: {lastUpdated}</div>
			</div>
		</section>

		<!-- Content -->
		<section class="content-section">
			<div class="container">
				<div class="policy-layout">

					<!-- Table of Contents -->
					<aside class="toc">
						<h3>المحتويات</h3>
						<nav>
							<a href="#acceptance">1. قبول الشروط</a>
							<a href="#services">2. وصف الخدمات</a>
							<a href="#use-rules">3. قواعد الاستخدام</a>
							<a href="#intellectual">4. الملكية الفكرية</a>
							<a href="#disclaimer">5. إخلاء المسؤولية</a>
							<a href="#liability">6. تحديد المسؤولية</a>
							<a href="#links">7. روابط خارجية</a>
							<a href="#affiliate">8. الروابط التابعة</a>
							<a href="#termination">9. إنهاء الخدمة</a>
							<a href="#governing">10. القانون الحاكم</a>
							<a href="#changes">11. التغييرات على الشروط</a>
							<a href="#contact">12. تواصل معنا</a>
						</nav>
					</aside>

					<!-- Main Content -->
					<div class="policy-content">

						<div class="notice-box notice-info">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
							</svg>
							<p>باستخدامك لموقع <strong>خدمات الذكاء الاصطناعي</strong>، فإنك تقر بأنك قرأت هذه الشروط وفهمتها ووافقت على الالتزام بها.</p>
						</div>

						<div class="policy-section" id="acceptance">
							<h2>
								<span class="section-num">1</span>
								قبول الشروط
							</h2>
							<p>
								تحكم هذه الشروط والأحكام ("الشروط") استخدامك لموقع <strong>خدمات الذكاء الاصطناعي</strong> المتاح على العنوان khadamatelai.xyz وجميع الخدمات المرتبطة به.
							</p>
							<p>
								إذا كنت تستخدم الموقع نيابةً عن شركة أو منظمة، فإنك تقر بأن لديك الصلاحية للموافقة على هذه الشروط نيابةً عنها، وأن الشركة أو المنظمة توافق على الالتزام بهذه الشروط.
							</p>
							<p>
								إذا كنت لا توافق على هذه الشروط، يُرجى التوقف عن استخدام الموقع فورًا.
							</p>
						</div>

						<div class="policy-section" id="services">
							<h2>
								<span class="section-num">2</span>
								وصف الخدمات
							</h2>
							<p>يقدم موقع خدمات الذكاء الاصطناعي الخدمات التالية:</p>
							<div class="services-grid">
								<div class="service-item">
									<div class="service-icon">📝</div>
									<div>
										<h4>المحتوى التعليمي</h4>
										<p>مقالات وأدلة ودروس تعليمية حول أدوات وتقنيات الذكاء الاصطناعي.</p>
									</div>
								</div>
								<div class="service-item">
									<div class="service-icon">🔧</div>
									<div>
										<h4>مراجعات الأدوات</h4>
										<p>تقييمات ومقارنات لأدوات الذكاء الاصطناعي المختلفة.</p>
									</div>
								</div>
								<div class="service-item">
									<div class="service-icon">💼</div>
									<div>
										<h4>الخدمات الاحترافية</h4>
										<p>حلول مخصصة لتطبيق الذكاء الاصطناعي في الأعمال.</p>
									</div>
								</div>
								<div class="service-item">
									<div class="service-icon">📱</div>
									<div>
										<h4>التطبيقات</h4>
										<p>تطبيقات ذكية تعتمد على تقنيات الذكاء الاصطناعي.</p>
									</div>
								</div>
							</div>
							<p>
								نحتفظ بالحق في تعديل أو إيقاف أي من خدماتنا في أي وقت دون إشعار مسبق.
							</p>
						</div>

						<div class="policy-section" id="use-rules">
							<h2>
								<span class="section-num">3</span>
								قواعد الاستخدام
							</h2>
							<p>عند استخدام موقعنا، توافق على عدم القيام بما يلي:</p>

							<div class="rules-list">
								<div class="rule-item rule-forbidden">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/>
									</svg>
									<span>نشر أو نقل أي محتوى غير قانوني أو ضار أو مسيء أو تشهيري.</span>
								</div>
								<div class="rule-item rule-forbidden">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/>
									</svg>
									<span>انتهاك حقوق الملكية الفكرية أو أي حقوق أخرى لأطراف ثالثة.</span>
								</div>
								<div class="rule-item rule-forbidden">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/>
									</svg>
									<span>محاولة الوصول غير المصرح به إلى أنظمتنا أو قواعد بياناتنا.</span>
								</div>
								<div class="rule-item rule-forbidden">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/>
									</svg>
									<span>استخدام الموقع لأغراض تجارية دون إذن كتابي مسبق منا.</span>
								</div>
								<div class="rule-item rule-forbidden">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/>
									</svg>
									<span>نشر برامج ضارة أو فيروسات أو أي كود ضار آخر.</span>
								</div>
								<div class="rule-item rule-forbidden">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/>
									</svg>
									<span>جمع بيانات المستخدمين الآخرين دون موافقتهم.</span>
								</div>
							</div>
						</div>

						<div class="policy-section" id="intellectual">
							<h2>
								<span class="section-num">4</span>
								الملكية الفكرية
							</h2>
							<p>
								جميع المحتويات المنشورة على موقعنا، بما في ذلك النصوص والصور والرسومات والشعارات والمقاطع الصوتية والمرئية، هي ملك حصري لـ <strong>خدمات الذكاء الاصطناعي</strong> أو لأصحابها المرخصين، وهي محمية بموجب قوانين حقوق النشر والملكية الفكرية.
							</p>
							<div class="highlight-box">
								<h4>ما يُسمح به:</h4>
								<ul class="styled-list">
									<li>مشاركة روابط مقالاتنا على وسائل التواصل الاجتماعي.</li>
									<li>اقتباس فقرات قصيرة مع الإشارة الواضحة للمصدر.</li>
									<li>استخدام المحتوى للأغراض الشخصية غير التجارية.</li>
								</ul>
							</div>
							<div class="highlight-box highlight-red">
								<h4>ما لا يُسمح به:</h4>
								<ul class="styled-list">
									<li>نسخ أو إعادة نشر المحتوى كاملًا دون إذن.</li>
									<li>استخدام المحتوى لأغراض تجارية دون ترخيص.</li>
									<li>إزالة إشارات حقوق النشر أو العلامات التجارية.</li>
								</ul>
							</div>
						</div>

						<div class="policy-section" id="disclaimer">
							<h2>
								<span class="section-num">5</span>
								إخلاء المسؤولية
							</h2>
							<p>
								يُقدَّم محتوى موقعنا "كما هو" لأغراض إعلامية وتعليمية فقط. على الرغم من حرصنا على دقة المعلومات وتحديثها، إلا أننا لا نضمن:
							</p>
							<ul class="styled-list">
								<li>دقة أو اكتمال أو حداثة جميع المعلومات المنشورة.</li>
								<li>ملاءمة المحتوى لاحتياجاتك أو ظروفك الخاصة.</li>
								<li>النتائج التي قد تحصل عليها من تطبيق المعلومات الواردة في موقعنا.</li>
								<li>توافر الموقع بشكل مستمر وخالٍ من الأخطاء.</li>
							</ul>
							<div class="notice-box notice-warning">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
								</svg>
								<p>المعلومات المتعلقة بالاستثمار والمال لا تُعدّ نصيحة مالية مهنية. استشر متخصصًا ماليًا مؤهلًا قبل اتخاذ أي قرارات استثمارية.</p>
							</div>
						</div>

						<div class="policy-section" id="liability">
							<h2>
								<span class="section-num">6</span>
								تحديد المسؤولية
							</h2>
							<p>
								إلى أقصى حد يسمح به القانون المعمول به، لن تكون <strong>خدمات الذكاء الاصطناعي</strong> مسؤولة عن أي أضرار مباشرة أو غير مباشرة أو عرضية أو خاصة أو تبعية تنشأ عن:
							</p>
							<ul class="styled-list">
								<li>استخدامك أو عدم قدرتك على استخدام موقعنا أو خدماتنا.</li>
								<li>أي أخطاء أو سهو في المحتوى.</li>
								<li>الوصول غير المصرح به إلى بياناتك أو تغييرها.</li>
								<li>أي مسألة تتعلق بخدمات الأطراف الثالثة المرتبطة بموقعنا.</li>
							</ul>
						</div>

						<div class="policy-section" id="links">
							<h2>
								<span class="section-num">7</span>
								روابط خارجية
							</h2>
							<p>
								قد يحتوي موقعنا على روابط لمواقع خارجية لا نتحكم فيها. هذه الروابط مقدمة لراحتك فقط، ولا تعني موافقتنا على محتوى تلك المواقع أو مسؤوليتنا عنها.
							</p>
							<p>
								ننصحك بمراجعة سياسات الخصوصية والشروط الخاصة بكل موقع خارجي تزوره. لسنا مسؤولين عن أي محتوى أو ممارسات خصوصية أو خدمات تقدمها تلك المواقع.
							</p>
						</div>

						<div class="policy-section" id="affiliate">
							<h2>
								<span class="section-num">8</span>
								الروابط التابعة (Affiliate Links)
							</h2>
							<p>
								قد يحتوي موقعنا على روابط تابعة (Affiliate Links) لمنتجات وخدمات. هذا يعني أننا قد نحصل على عمولة إذا قمت بالشراء من خلال هذه الروابط، دون أي تكلفة إضافية عليك.
							</p>
							<div class="notice-box notice-info">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
								</svg>
								<p>نلتزم بالشفافية الكاملة: توصياتنا مبنية على تقييمنا الصادق للمنتجات والخدمات، وليس فقط على العمولات المحتملة.</p>
							</div>
						</div>

						<div class="policy-section" id="termination">
							<h2>
								<span class="section-num">9</span>
								إنهاء الخدمة
							</h2>
							<p>
								نحتفظ بالحق في إنهاء أو تعليق وصولك إلى موقعنا وخدماتنا، بشكل فوري ودون إشعار مسبق، إذا انتهكت هذه الشروط أو إذا رأينا أن استخدامك يضر بالموقع أو بمستخدمين آخرين.
							</p>
							<p>
								يمكنك أيضًا التوقف عن استخدام موقعنا في أي وقت. جميع الأحكام التي يجب أن تستمر بطبيعتها بعد الإنهاء ستظل سارية المفعول.
							</p>
						</div>

						<div class="policy-section" id="governing">
							<h2>
								<span class="section-num">10</span>
								القانون الحاكم
							</h2>
							<p>
								تخضع هذه الشروط وتُفسَّر وفقًا للقوانين المعمول بها. أي نزاع ينشأ عن هذه الشروط أو يتعلق بها سيُحسم بالتفاوض الودي أولًا، وإذا تعذر ذلك، يُلجأ إلى الجهات القانونية المختصة.
							</p>
						</div>

						<div class="policy-section" id="changes">
							<h2>
								<span class="section-num">11</span>
								التغييرات على الشروط
							</h2>
							<p>
								نحتفظ بالحق في تعديل هذه الشروط في أي وقت. سيتم نشر الشروط المحدثة على هذه الصفحة مع تحديث تاريخ "آخر تحديث". استمرارك في استخدام الموقع بعد نشر التغييرات يعني موافقتك على الشروط الجديدة.
							</p>
							<p>
								ننصحك بمراجعة هذه الصفحة بشكل دوري للاطلاع على أي تغييرات.
							</p>
						</div>

						<div class="policy-section" id="contact">
							<h2>
								<span class="section-num">12</span>
								تواصل معنا
							</h2>
							<p>إذا كان لديك أي أسئلة أو استفسارات حول هذه الشروط، يمكنك التواصل معنا:</p>
							<div class="contact-card">
								<div class="contact-item">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
									</svg>
									<a href="mailto:info@khadamatelai.xyz">info@khadamatelai.xyz</a>
								</div>
								<div class="contact-item">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
									</svg>
									<a href="https://khadamatelai.xyz">khadamatelai.xyz</a>
								</div>
							</div>

							<div class="related-links">
								<p>قد تهمك أيضًا:</p>
								<div class="related-btns">
									<a href="/privacy-policy" class="related-btn">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
										</svg>
										سياسة الخصوصية
									</a>
									<a href="/about" class="related-btn">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
										</svg>
										من نحن
									</a>
								</div>
							</div>
						</div>

					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	main {
		min-height: 100vh;
	}

	/* Hero */
	.page-hero {
		background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #0d9488 100%);
		color: white;
		padding: 5rem 0 3.5rem;
		text-align: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255,255,255,0.15);
		border: 1px solid rgba(255,255,255,0.3);
		color: white;
		padding: 0.4rem 1.2rem;
		border-radius: 2rem;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		backdrop-filter: blur(10px);
	}

	.page-hero h1 {
		color: white;
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		margin-bottom: 1rem;
	}

	.hero-subtitle {
		color: rgba(255,255,255,0.85);
		font-size: 1.1rem;
		max-width: 620px;
		margin: 0 auto 1.5rem;
	}

	.last-updated {
		display: inline-block;
		background: rgba(255,255,255,0.1);
		color: rgba(255,255,255,0.7);
		padding: 0.3rem 1rem;
		border-radius: 1rem;
		font-size: 0.85rem;
	}

	/* Layout */
	.content-section {
		padding: 4rem 0 5rem;
		background: #f8fafc;
	}

	.policy-layout {
		display: grid;
		grid-template-columns: 240px 1fr;
		gap: 3rem;
		align-items: start;
	}

	/* TOC */
	.toc {
		position: sticky;
		top: 2rem;
		background: white;
		border-radius: 1rem;
		padding: 1.5rem;
		box-shadow: 0 4px 20px rgba(0,0,0,0.06);
		border: 1px solid #e2e8f0;
	}

	.toc h3 {
		color: #0f172a;
		font-size: 1rem;
		margin-bottom: 1rem;
		padding-bottom: 0.75rem;
		border-bottom: 2px solid #0d9488;
	}

	.toc nav {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.toc nav a {
		color: #64748b;
		font-size: 0.875rem;
		padding: 0.35rem 0.5rem;
		border-radius: 0.4rem;
		transition: all 0.2s ease;
		text-decoration: none;
	}

	.toc nav a:hover {
		color: #0d9488;
