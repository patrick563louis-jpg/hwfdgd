---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = "21 مارس 2026";
---

<Layout title="سياسة الخصوصية | خدمات الذكاء الاصطناعي" description="سياسة الخصوصية لموقع خدمات الذكاء الاصطناعي - تعرف على كيفية جمع واستخدام وحماية بياناتك الشخصية">
	<Header />

	<main>
		<!-- Hero -->
		<section class="page-hero">
			<div class="container">
				<div class="hero-badge">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
					</svg>
					سياسة الخصوصية
				</div>
				<h1>سياسة الخصوصية</h1>
				<p class="hero-subtitle">نحن نأخذ خصوصيتك على محمل الجد. تعرف على كيفية جمع بياناتك واستخدامها وحمايتها.</p>
				<div class="last-updated">آخر تحديث: {lastUpdated}</div>
			</div>
		</section>

		<!-- Content -->
		<section class="content-section">
			<div class="container">
				<div class="policy-layout">

					<!-- Table of Contents -->
					<aside class="toc">
						<h3>المحتويات</h3>
						<nav>
							<a href="#intro">1. مقدمة</a>
							<a href="#data-collected">2. البيانات التي نجمعها</a>
							<a href="#data-use">3. كيف نستخدم بياناتك</a>
							<a href="#cookies">4. ملفات تعريف الارتباط</a>
							<a href="#third-party">5. الأطراف الثالثة</a>
							<a href="#data-security">6. أمان البيانات</a>
							<a href="#your-rights">7. حقوقك</a>
							<a href="#children">8. خصوصية الأطفال</a>
							<a href="#changes">9. التغييرات على السياسة</a>
							<a href="#contact">10. تواصل معنا</a>
						</nav>
					</aside>

					<!-- Main Content -->
					<div class="policy-content">

						<div class="policy-section" id="intro">
							<h2>
								<span class="section-num">1</span>
								مقدمة
							</h2>
							<p>
								مرحبًا بك في موقع <strong>خدمات الذكاء الاصطناعي</strong> (khadamatelai.xyz). نحن نلتزم بحماية خصوصيتك وضمان أمان بياناتك الشخصية. تصف سياسة الخصوصية هذه كيفية جمع معلوماتك واستخدامها والإفصاح عنها عند استخدامك لموقعنا وخدماتنا.
							</p>
							<p>
								باستخدامك لموقعنا، فإنك توافق على الممارسات الموضحة في هذه السياسة. إذا كنت لا توافق على هذه السياسة، يُرجى عدم استخدام موقعنا.
							</p>
						</div>

						<div class="policy-section" id="data-collected">
							<h2>
								<span class="section-num">2</span>
								البيانات التي نجمعها
							</h2>
							<p>قد نجمع الأنواع التالية من المعلومات:</p>

							<div class="info-card">
								<h4>
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"/>
									</svg>
									معلومات شخصية
								</h4>
								<ul>
									<li>الاسم وعنوان البريد الإلكتروني عند التواصل معنا أو الاشتراك في النشرة البريدية.</li>
									<li>أي معلومات تقدمها طوعًا عبر نماذج التواصل.</li>
								</ul>
							</div>

							<div class="info-card">
								<h4>
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
									</svg>
									بيانات الاستخدام
								</h4>
								<ul>
									<li>عنوان IP ونوع المتصفح ونظام التشغيل.</li>
									<li>الصفحات التي تزورها ومدة الزيارة.</li>
									<li>مصدر الزيارة (محرك البحث، رابط مباشر، إلخ).</li>
								</ul>
							</div>

							<div class="info-card">
								<h4>
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M5 12h14M12 5l7 7-7 7"/>
									</svg>
									ملفات تعريف الارتباط
								</h4>
								<ul>
									<li>ملفات تعريف الارتباط الضرورية لعمل الموقع.</li>
									<li>ملفات تعريف الارتباط التحليلية لفهم كيفية استخدام الموقع.</li>
								</ul>
							</div>
						</div>

						<div class="policy-section" id="data-use">
							<h2>
								<span class="section-num">3</span>
								كيف نستخدم بياناتك
							</h2>
							<p>نستخدم المعلومات التي نجمعها للأغراض التالية:</p>
							<ul class="styled-list">
								<li>تشغيل الموقع وتحسين تجربة المستخدم.</li>
								<li>الرد على استفساراتك وطلباتك.</li>
								<li>إرسال النشرة البريدية والتحديثات (بموافقتك).</li>
								<li>تحليل أنماط الاستخدام لتحسين محتوانا وخدماتنا.</li>
								<li>الامتثال للمتطلبات القانونية.</li>
								<li>منع الاحتيال وضمان أمان الموقع.</li>
							</ul>
						</div>

						<div class="policy-section" id="cookies">
							<h2>
								<span class="section-num">4</span>
								ملفات تعريف الارتباط (Cookies)
							</h2>
							<p>
								نستخدم ملفات تعريف الارتباط لتحسين تجربتك على موقعنا. يمكنك التحكم في ملفات تعريف الارتباط من خلال إعدادات متصفحك. لاحظ أن تعطيل بعض ملفات تعريف الارتباط قد يؤثر على وظائف الموقع.
							</p>
							<div class="table-wrapper">
								<table>
									<thead>
										<tr>
											<th>النوع</th>
											<th>الغرض</th>
											<th>المدة</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td>ضرورية</td>
											<td>تشغيل الموقع الأساسي</td>
											<td>الجلسة</td>
										</tr>
										<tr>
											<td>تحليلية</td>
											<td>قياس أداء الموقع</td>
											<td>سنة واحدة</td>
										</tr>
										<tr>
											<td>تفضيلات</td>
											<td>حفظ إعداداتك</td>
											<td>سنة واحدة</td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>

						<div class="policy-section" id="third-party">
							<h2>
								<span class="section-num">5</span>
								الأطراف الثالثة
							</h2>
							<p>
								لا نبيع بياناتك الشخصية لأطراف ثالثة. ومع ذلك، قد نشارك بعض البيانات مع مزودي الخدمات الموثوقين الذين يساعدوننا في تشغيل الموقع، مثل:
							</p>
							<ul class="styled-list">
								<li><strong>Google Analytics:</strong> لتحليل حركة الزوار وتحسين الموقع.</li>
								<li><strong>مزودو الاستضافة:</strong> لتخزين بيانات الموقع وتشغيله.</li>
								<li><strong>خدمات البريد الإلكتروني:</strong> لإرسال النشرات البريدية.</li>
							</ul>
							<p>
								جميع هؤلاء المزودين ملزمون بالحفاظ على سرية بياناتك واستخدامها فقط للأغراض المحددة.
							</p>
						</div>

						<div class="policy-section" id="data-security">
							<h2>
								<span class="section-num">6</span>
								أمان البيانات
							</h2>
							<p>
								نتخذ تدابير أمنية مناسبة لحماية بياناتك من الوصول غير المصرح به أو التغيير أو الإفصاح أو الإتلاف. تشمل هذه التدابير:
							</p>
							<ul class="styled-list">
								<li>تشفير البيانات أثناء النقل باستخدام بروتوكول HTTPS.</li>
								<li>تقييد الوصول إلى البيانات الشخصية على الموظفين المصرح لهم فقط.</li>
								<li>مراجعة دورية لممارسات جمع البيانات وتخزينها ومعالجتها.</li>
							</ul>
							<div class="notice-box notice-warning">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
								</svg>
								<p>لا يوجد نظام أمان مضمون بنسبة 100%. في حال حدوث أي اختراق أمني يؤثر على بياناتك، سنخطرك في أقرب وقت ممكن.</p>
							</div>
						</div>

						<div class="policy-section" id="your-rights">
							<h2>
								<span class="section-num">7</span>
								حقوقك
							</h2>
							<p>لديك الحقوق التالية فيما يتعلق ببياناتك الشخصية:</p>
							<div class="rights-grid">
								<div class="right-item">
									<div class="right-icon">🔍</div>
									<h4>حق الوصول</h4>
									<p>طلب نسخة من بياناتك الشخصية التي نحتفظ بها.</p>
								</div>
								<div class="right-item">
									<div class="right-icon">✏️</div>
									<h4>حق التصحيح</h4>
									<p>طلب تصحيح أي بيانات غير دقيقة أو غير مكتملة.</p>
								</div>
								<div class="right-item">
									<div class="right-icon">🗑️</div>
									<h4>حق الحذف</h4>
									<p>طلب حذف بياناتك الشخصية في ظروف معينة.</p>
								</div>
								<div class="right-item">
									<div class="right-icon">🚫</div>
									<h4>حق الاعتراض</h4>
									<p>الاعتراض على معالجة بياناتك لأغراض معينة.</p>
								</div>
							</div>
							<p>لم ممارسة أي من هذه الحقوق، تواصل معنا على: <a href="mailto:info@khadamatelai.xyz">info@khadamatelai.xyz</a></p>
						</div>

						<div class="policy-section" id="children">
							<h2>
								<span class="section-num">8</span>
								خصوصية الأطفال
							</h2>
							<p>
								موقعنا غير موجه للأطفال دون سن 13 عامًا. لا نجمع عن قصد معلومات شخصية من الأطفال. إذا علمنا بأننا جمعنا بيانات من طفل دون موافقة الوالدين، سنتخذ خطوات فورية لحذف هذه المعلومات.
							</p>
						</div>

						<div class="policy-section" id="changes">
							<h2>
								<span class="section-num">9</span>
								التغييرات على السياسة
							</h2>
							<p>
								قد نقوم بتحديث سياسة الخصوصية هذه من وقت لآخر. سنخطرك بأي تغييرات جوهرية عن طريق نشر السياسة الجديدة على هذه الصفحة وتحديث تاريخ "آخر تحديث". ننصحك بمراجعة هذه الصفحة بشكل دوري.
							</p>
						</div>

						<div class="policy-section" id="contact">
							<h2>
								<span class="section-num">10</span>
								تواصل معنا
							</h2>
							<p>إذا كان لديك أي أسئلة حول سياسة الخصوصية هذه، يمكنك التواصل معنا:</p>
							<div class="contact-card">
								<div class="contact-item">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
									</svg>
									<a href="mailto:info@khadamatelai.xyz">info@khadamatelai.xyz</a>
								</div>
								<div class="contact-item">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
									</svg>
									<a href="https://khadamatelai.xyz">khadamatelai.xyz</a>
								</div>
							</div>
						</div>

					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	main {
		min-height: 100vh;
	}

	/* Hero */
	.page-hero {
		background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #0d9488 100%);
		color: white;
		padding: 5rem 0 3.5rem;
		text-align: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255,255,255,0.15);
		border: 1px solid rgba(255,255,255,0.3);
		color: white;
		padding: 0.4rem 1.2rem;
		border-radius: 2rem;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		backdrop-filter: blur(10px);
	}

	.page-hero h1 {
		color: white;
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		margin-bottom: 1rem;
	}

	.hero-subtitle {
		color: rgba(255,255,255,0.85);
		font-size: 1.1rem;
		max-width: 600px;
		margin: 0 auto 1.5rem;
	}

	.last-updated {
		display: inline-block;
		background: rgba(255,255,255,0.1);
		color: rgba(255,255,255,0.7);
		padding: 0.3rem 1rem;
		border-radius: 1rem;
		font-size: 0.85rem;
	}

	/* Layout */
	.content-section {
		padding: 4rem 0 5rem;
		background: #f8fafc;
	}

	.policy-layout {
		display: grid;
		grid-template-columns: 240px 1fr;
		gap: 3rem;
		align-items: start;
	}

	/* TOC */
	.toc {
		position: sticky;
		top: 2rem;
		background: white;
		border-radius: 1rem;
		padding: 1.5rem;
		box-shadow: 0 4px 20px rgba(0,0,0,0.06);
		border: 1px solid #e2e8f0;
	}

	.toc h3 {
		color: #0f172a;
		font-size: 1rem;
		margin-bottom: 1rem;
		padding-bottom: 0.75rem;
		border-bottom: 2px solid #0d9488;
	}

	.toc nav {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.toc nav a {
		color: #64748b;
		font-size: 0.875rem;
		padding: 0.35rem 0.5rem;
		border-radius: 0.4rem;
		transition: all 0.2s ease;
		text-decoration: none;
	}

	.toc nav a:hover {
		color: #0d9488;
		background: #f0fdfa;
	}

	/* Policy Content */
	.policy-content {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.policy-section {
		background: white;
		border-radius: 1rem;
		padding: 2.5rem;
		margin-bottom: 1.5rem;
		box-shadow: 0 2px 12px rgba(0,0,0,0.04);
		border: 1px solid #e2e8f0;
	}

	.policy-section h2 {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: #0f172a;
		font-size: 1.35rem;
		margin-bottom: 1.25rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid #f1f5f9;
	}

	.section-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		background: linear-gradient(135deg, #0d9488, #1e3a8a);
		color: white;
		border-radius: 50%;
		font-size: 0.85rem;
		font-weight: 700;
		flex-shrink: 0;
	}

	.policy-section p {
		color: #475569;
		line-height: 1.8;
		margin-bottom: 1rem;
	}

	.policy-section p:last-child {
		margin-bottom: 0;
	}

	/* Info Cards */
	.info-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 0.75rem;
		padding: 1.25rem 1.5rem;
		margin-bottom: 1rem;
	}

	.info-card h4 {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #0f172a;
		font-size: 1rem;
		margin-bottom: 0.75rem;
	}

	.info-card ul {
		padding-right: 1.25rem;
		margin: 0;
	}

	.info-card ul li {
		color: #475569;
		font-size: 0.95rem;
		line-height: 1.7;
		margin-bottom: 0.4rem;
	}

	/* Styled List */
	.styled-list {
		padding-right: 1.5rem;
		margin: 0.75rem 0;
	}

	.styled-list li {
		color: #475569;
		line-height: 1.8;
		margin-bottom: 0.5rem;
		position: relative;
	}

	.styled-list li::marker {
		color: #0d9488;
	}

	/* Table */
	.table-wrapper {
		overflow-x: auto;
		margin-top: 1rem;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.95rem;
	}

	th {
		background: #0f172a;
		color: white;
		padding: 0.75rem 1rem;
		text-align: right;
		font-weight: 600;
	}

	td {
		padding: 0.75rem 1rem;
		border-bottom: 1px solid #e2e8f0;
		color: #475569;
	}

	tr:last-child td {
		border-bottom: none;
	}

	tr:nth-child(even) td {
		background: #f8fafc;
	}

	/* Notice Box */
	.notice-box {
		display: flex;
		gap: 0.75rem;
		align-items: flex-start;
		padding: 1rem 1.25rem;
		border-radius: 0.75rem;
		margin-top: 1rem;
	}

	.notice-warning {
		background: #fffbeb;
		border: 1px solid #fcd34d;
		color: #92400e;
	}

	.notice-warning svg {
		color: #d97706;
		flex-shrink: 0;
		margin-top: 2px;
	}

	.notice-box p {
		color: #92400e !important;
		margin: 0 !important;
		font-size: 0.9rem;
	}

	/* Rights Grid */
	.rights-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1rem;
		margin: 1.25rem 0;
	}

	.right-item {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 0.75rem;
		padding: 1.25rem;
		text-align: center;
		transition: border-color 0.3s ease;
	}

	.right-item:hover {
		border-color: #0d9488;
	}

	.right-icon {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.right-item h4 {
		color: #0f172a;
		font-size: 0.95rem;
		margin-bottom: 0.4rem;
	}

	.right-item p {
		color: #64748b;
		font-size: 0.85rem;
