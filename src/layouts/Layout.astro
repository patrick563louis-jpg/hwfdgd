---
import AdSenseScript from '../components/AdSenseScript.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: URL;
}

const {
	title = 'خدمات الذكاء الاصطناعي | المنصة العربية الشاملة لتقنيات AI',
	description = 'خدمات الذكاء الاصطناعي هي وجهتك الأولى لاكتشاف وتطبيق أحدث تقنيات AI في العالم العربي. نوفر أدوات ذكية، شروحات تقنية، واستراتيجيات مبتكرة لزيادة الإنتاجية وتحقيق النجاح الرقمي.',
	image = '/media/images/general-ai.jpg',
	canonicalURL = new URL(Astro.url.pathname, 'https://khadamatelai.xyz'),
} = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Performance Optimization: Preconnect to external domains -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preconnect" href="https://pagead2.googlesyndication.com">
		<link rel="dns-prefetch" href="https://pagead2.googlesyndication.com">

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content="ذكاء اصطناعي, خدمات ذكاء اصطناعي, أدوات ذكاء اصطناعي, الربح من الذكاء الاصطناعي, Money AI, تطبيقات ذكاء اصطناعي, توليد الصور بالذكاء الاصطناعي, صناعة الفيديو بالذكاء الاصطناعي, أفضل أدوات AI, تعلم الذكاء الاصطناعي, استثمار ذكي, أتمتة الأعمال" />
		<meta name="google-site-verification" content="yOLNd2E5QtY4SzIMAfsbZW7qp4_MsHR3NTImFSGP9Ws" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />

		<!-- JSON-LD Schema Markup -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "خدمات الذكاء الاصطناعي",
			"alternateName": "AI Services",
			"url": "https://khadamatelai.xyz",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://khadamatelai.xyz/posts?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "خدمات الذكاء الاصطناعي",
			"url": "https://khadamatelai.xyz",
			"logo": "https://khadamatelai.xyz/favicon.svg",
			"sameAs": [
				"https://www.youtube.com/@khadamatelai",
				"https://t.me/khadamatelai",
				"https://www.tiktok.com/@khadamaatelai",
				"https://whatsapp.com/channel/0029VbCBuE44NVirlDLKkl0N"
			]
		})} />

		<!-- Breadcrumb Schema -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "الرئيسية",
					"item": "https://khadamatelai.xyz"
				},
				...(Astro.url.pathname !== '/' ? [{
					"@type": "ListItem",
					"position": 2,
					"name": title.split('|')[0].trim(),
					"item": canonicalURL.toString()
				}] : [])
			]
		})} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
		</noscript>
		
		<slot name="head" />
		<AdSenseScript />
	</head>
	<body>
		<slot />

		<!-- Floating Social Media Icons -->
		<div class="social-float">
			<a href="https://youtube.com/@tatbikaatelai" aria-label="YouTube" class="social-float-btn youtube" target="_blank" rel="noopener noreferrer">
				<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
					<path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
				</svg>
			</a>
			<a href="https://t.me/khadamatelai" aria-label="Telegram" class="social-float-btn telegram" target="_blank" rel="noopener noreferrer">
				<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
					<path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
				</svg>
			</a>
			<a href="https://whatsapp.com/channel/0029VbCBuE44NVirlDLKkl0N" aria-label="WhatsApp" class="social-float-btn whatsapp" target="_blank" rel="noopener noreferrer">
				<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
				</svg>
			</a>
			<a href="https://www.tiktok.com/@khadamaatelai" aria-label="TikTok" class="social-float-btn tiktok" target="_blank" rel="noopener noreferrer">
				<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
					<path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
				</svg>
			</a>
			<a href="https://www.linkedin.com/in/خدمات-الذكاء-الاصطناعي-6b23323b9?utm_source=share_via&utm_content=profile&utm_medium=member_android" aria-label="LinkedIn" class="social-float-btn linkedin" target="_blank" rel="noopener noreferrer">
				<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
